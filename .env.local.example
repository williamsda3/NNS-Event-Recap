# SharePoint Configuration (Optional)
# These can also be configured in the app UI

# Your SharePoint site URL (without the document library path)
# Example: https://yourcompany.sharepoint.com/sites/OutreachTeam
NEXT_PUBLIC_SHAREPOINT_BASE_URL=

# The name of the document library for event photos
# Example: Event Photos
NEXT_PUBLIC_SHAREPOINT_LIBRARY_NAME=Event Photos

# Azure AD / Entra ID Configuration (Required for photo upload to SharePoint)
# Create an app registration at https://portal.azure.com → Entra ID → App registrations
# Grant Microsoft Graph API permissions: Sites.ReadWrite.All, Files.ReadWrite.All
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# SharePoint Site & Drive IDs (Required for photo upload)
# Get Site ID: GET https://graph.microsoft.com/v1.0/sites/{hostname}:/{site-path}
# Get Drive ID: GET https://graph.microsoft.com/v1.0/sites/{site-id}/drives
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
